{
  "name": "pentimento",
  "displayName": "Pentimento",
  "description": "在真实代码上下文中高亮 Git Patch 新增的内容。",
  "version": "0.0.1",
  "publisher": "pentimento-contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SuPerCxyz/pentimento.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "SCM Providers",
    "Visualization"
  ],
  "keywords": [
    "git",
    "diff",
    "patch",
    "blame",
    "highlight",
    "history",
    "commit"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      { "command": "pentimento.addCommitFromLine", "title": "Pentimento: 从当前行添加提交到高亮" },
      { "command": "pentimento.highlightOnlyCommitFromLine", "title": "Pentimento: 仅高亮当前行提交" },
      { "command": "pentimento.toggleCommitFromLine", "title": "Pentimento: 切换当前行提交高亮" },
      { "command": "pentimento.addRef", "title": "Pentimento: 添加提交或范围" },
      { "command": "pentimento.highlightWorkingTree", "title": "Pentimento: 高亮工作区修改" },
      { "command": "pentimento.highlightStaged", "title": "Pentimento: 高亮暂存区修改" },
      { "command": "pentimento.highlightSurvivingLines", "title": "Pentimento: 在当前版本高亮存活行" },
      { "command": "pentimento.openExactPatchRevision", "title": "Pentimento: 打开精确 Patch 版本" },
      { "command": "pentimento.projectOntoCurrentRevision", "title": "Pentimento: 投影到当前版本" },
      { "command": "pentimento.setPrimaryPatch", "title": "Pentimento: 设为主要 Patch" },
      { "command": "pentimento.togglePatchVisibility", "title": "Pentimento: 显示或隐藏 Patch" },
      { "command": "pentimento.removePatch", "title": "Pentimento: 移除 Patch" },
      { "command": "pentimento.managePatches", "title": "Pentimento: 管理已高亮 Patch" },
      { "command": "pentimento.highlightCurrentFile", "title": "Pentimento: 仅高亮当前文件" },
      { "command": "pentimento.highlightAllFiles", "title": "Pentimento: 高亮全部变更文件" },
      { "command": "pentimento.showFiles", "title": "Pentimento: 显示变更文件" },
      { "command": "pentimento.nextHunk", "title": "Pentimento: 下一个新增 Hunk" },
      { "command": "pentimento.previousHunk", "title": "Pentimento: 上一个新增 Hunk" },
      { "command": "pentimento.showOnlyPrimary", "title": "Pentimento: 仅显示主要 Patch" },
      { "command": "pentimento.showAll", "title": "Pentimento: 显示全部 Patch" },
      { "command": "pentimento.hideAll", "title": "Pentimento: 隐藏全部 Patch" },
      { "command": "pentimento.toggle", "title": "Pentimento: 切换高亮" },
      { "command": "pentimento.refresh", "title": "Pentimento: 刷新高亮" },
      { "command": "pentimento.clearAll", "title": "Pentimento: 清除全部 Patch" },
      { "command": "pentimento.switchHistoricalViewMode", "title": "Pentimento: 切换历史查看模式" },
      { "command": "pentimento.showEvolutionSummary", "title": "Pentimento: 显示 Patch 演化摘要" },
      { "command": "pentimento.closeExactWorkspace", "title": "Pentimento: 关闭精确 Patch 工作区" },
      { "command": "pentimento.removeTemporaryWorktree", "title": "Pentimento: 移除临时 Worktree" },
      { "command": "pentimento.cleanStaleWorktrees", "title": "Pentimento: 清理残留 Worktree" },
      { "command": "pentimento.openOutputLog", "title": "Pentimento: 打开输出日志" },
      { "command": "pentimento.showDiagnostics", "title": "Pentimento: 显示诊断" },
      { "command": "pentimento.setPatchColor", "title": "Pentimento: 设置 Patch 颜色" },
      { "command": "pentimento.fetch", "title": "Pentimento: Fetch 并刷新" },
      { "command": "pentimento.refreshCommits", "title": "Pentimento: 刷新提交列表" },
      { "command": "pentimento.highlightLineCommit", "title": "Pentimento: 高亮当前行提交(选模式)" },
      { "command": "pentimento.revealHunk", "title": "Pentimento: 跳转到 Hunk" },
      { "command": "pentimento.toggleCommitHighlight", "title": "Pentimento: 切换提交高亮" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pentimento",
          "title": "PENTIMENTO",
          "icon": "resources/pentimento.svg"
        }
      ]
    },
    "views": {
      "pentimento": [
        {
          "id": "pentimento.patches",
          "name": "补丁图层"
        },
        {
          "id": "pentimento.commits",
          "name": "提交列表"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "pentimento.patches",
        "contents": "尚未高亮任何 Git Patch。\n开始:在代码行悬停后点击「添加此提交到高亮」,或使用下方命令。\n[添加提交或范围](command:pentimento.addRef)\n[高亮工作区修改](command:pentimento.highlightWorkingTree)\n[高亮暂存区修改](command:pentimento.highlightStaged)\n[Fetch 并刷新](command:pentimento.fetch)",
        "when": "!pentimento.hasActivePatches"
      },
      {
        "view": "pentimento.commits",
        "contents": "尚未加载提交列表。\n打开一个 Git 仓库文件后,点击右上角刷新按钮,或:\n[刷新提交列表](command:pentimento.refreshCommits)\n\n点击列表中的提交即高亮其新增代码。"
      }
    ],
    "menus": {
      "commandPalette": [
        { "command": "pentimento.addCommitFromLine", "when": "pentimento.enabled" },
        { "command": "pentimento.highlightOnlyCommitFromLine", "when": "pentimento.enabled" },
        { "command": "pentimento.toggleCommitFromLine", "when": "pentimento.enabled" },
        { "command": "pentimento.addRef", "when": "pentimento.enabled" },
        { "command": "pentimento.highlightWorkingTree", "when": "pentimento.enabled" },
        { "command": "pentimento.highlightStaged", "when": "pentimento.enabled" },
        { "command": "pentimento.highlightSurvivingLines", "when": "pentimento.enabled" },
        { "command": "pentimento.openExactPatchRevision", "when": "pentimento.enabled" },
        { "command": "pentimento.projectOntoCurrentRevision", "when": "pentimento.hasActivePatches" },
        { "command": "pentimento.setPrimaryPatch", "when": "pentimento.hasActivePatches" },
        { "command": "pentimento.togglePatchVisibility", "when": "pentimento.hasActivePatches" },
        { "command": "pentimento.removePatch", "when": "pentimento.hasActivePatches" },
        { "command": "pentimento.managePatches", "when": "pentimento.enabled" },
        { "command": "pentimento.highlightCurrentFile", "when": "pentimento.enabled" },
        { "command": "pentimento.highlightAllFiles", "when": "pentimento.enabled" },
        { "command": "pentimento.showFiles", "when": "pentimento.hasActivePatches" },
        { "command": "pentimento.nextHunk", "when": "pentimento.hasActivePatches" },
        { "command": "pentimento.previousHunk", "when": "pentimento.hasActivePatches" },
        { "command": "pentimento.showOnlyPrimary", "when": "pentimento.hasActivePatches" },
        { "command": "pentimento.showAll", "when": "pentimento.hasActivePatches" },
        { "command": "pentimento.hideAll", "when": "pentimento.hasActivePatches" },
        { "command": "pentimento.toggle", "when": "pentimento.enabled" },
        { "command": "pentimento.refresh", "when": "pentimento.enabled" },
        { "command": "pentimento.clearAll", "when": "pentimento.hasActivePatches" },
        { "command": "pentimento.switchHistoricalViewMode", "when": "pentimento.hasActivePatches" },
        { "command": "pentimento.showEvolutionSummary", "when": "pentimento.hasActivePatches" },
        { "command": "pentimento.closeExactWorkspace", "when": "pentimento.exactWorkspace" },
        { "command": "pentimento.removeTemporaryWorktree", "when": "pentimento.enabled" },
        { "command": "pentimento.cleanStaleWorktrees", "when": "pentimento.enabled" },
        { "command": "pentimento.openOutputLog", "when": "true" },
        { "command": "pentimento.showDiagnostics", "when": "true" },
        { "command": "pentimento.setPatchColor", "when": "pentimento.hasActivePatches" },
        { "command": "pentimento.fetch", "when": "pentimento.enabled" },
        { "command": "pentimento.refreshCommits", "when": "pentimento.enabled" },
        { "command": "pentimento.highlightLineCommit", "when": "pentimento.enabled" },
        { "command": "pentimento.revealHunk", "when": "false" },
        { "command": "pentimento.toggleCommitHighlight", "when": "false" }
      ],
      "view/title": [
        {
          "command": "pentimento.addRef",
          "when": "view == pentimento.patches",
          "group": "navigation@1"
        },
        {
          "command": "pentimento.refresh",
          "when": "view == pentimento.patches",
          "group": "navigation@2"
        },
        {
          "command": "pentimento.clearAll",
          "when": "view == pentimento.patches && pentimento.hasActivePatches",
          "group": "navigation@3"
        },
        {
          "command": "pentimento.refreshCommits",
          "when": "view == pentimento.commits",
          "group": "navigation@1"
        }
      ],
      "editor/context": [
        {
          "command": "pentimento.highlightLineCommit",
          "when": "editorTextFocus && pentimento.enabled",
          "group": "pentimento@1"
        }
      ]
    },
    "colors": [
      { "id": "pentimento.patchLayer1Background", "description": "Patch 图层 1(绿)行背景。", "defaults": { "light": "#4ade8033", "dark": "#4ade8040", "highContrast": "#4ade8066" } },
      { "id": "pentimento.patchLayer1Border", "description": "Patch 图层 1 左边框。", "defaults": { "light": "#22c55ecc", "dark": "#4ade80ff", "highContrast": "#4ade80ff" } },
      { "id": "pentimento.patchLayer2Background", "description": "Patch 图层 2(青)行背景。", "defaults": { "light": "#22d3ee33", "dark": "#22d3ee40", "highContrast": "#22d3ee66" } },
      { "id": "pentimento.patchLayer2Border", "description": "Patch 图层 2 左边框。", "defaults": { "light": "#06b6d4cc", "dark": "#22d3eeff", "highContrast": "#22d3eeff" } },
      { "id": "pentimento.patchLayer3Background", "description": "Patch 图层 3(蓝)行背景。", "defaults": { "light": "#60a5fa33", "dark": "#60a5fa40", "highContrast": "#60a5fa66" } },
      { "id": "pentimento.patchLayer3Border", "description": "Patch 图层 3 左边框。", "defaults": { "light": "#3b82f6cc", "dark": "#60a5faff", "highContrast": "#60a5faff" } },
      { "id": "pentimento.patchLayer4Background", "description": "Patch 图层 4(紫)行背景。", "defaults": { "light": "#a78bfa33", "dark": "#a78bfa40", "highContrast": "#a78bfa66" } },
      { "id": "pentimento.patchLayer4Border", "description": "Patch 图层 4 左边框。", "defaults": { "light": "#8b5cf6cc", "dark": "#a78bfaff", "highContrast": "#a78bfaff" } },
      { "id": "pentimento.patchLayer5Background", "description": "Patch 图层 5(粉)行背景。", "defaults": { "light": "#f472b633", "dark": "#f472b640", "highContrast": "#f472b666" } },
      { "id": "pentimento.patchLayer5Border", "description": "Patch 图层 5 左边框。", "defaults": { "light": "#ec4899cc", "dark": "#f472b6ff", "highContrast": "#f472b6ff" } },
      { "id": "pentimento.patchLayer6Background", "description": "Patch 图层 6(橙)行背景。", "defaults": { "light": "#fbbf2433", "dark": "#fbbf2440", "highContrast": "#fbbf2466" } },
      { "id": "pentimento.patchLayer6Border", "description": "Patch 图层 6 左边框。", "defaults": { "light": "#f59e0bcc", "dark": "#fbbf24ff", "highContrast": "#fbbf24ff" } },
      { "id": "pentimento.overlapBackground", "description": "多个 Patch 重叠行的背景。", "defaults": { "light": "#f8717133", "dark": "#f8717140", "highContrast": "#f8717166" } },
      { "id": "pentimento.overlapBorder", "description": "重叠行左边框。", "defaults": { "light": "#ef4444cc", "dark": "#f87171ff", "highContrast": "#f87171ff" } },
      { "id": "pentimento.modifiedBackground", "description": "被后续修改的行的背景。", "defaults": { "light": "#facc1533", "dark": "#facc1540", "highContrast": "#facc1566" } },
      { "id": "pentimento.modifiedBorder", "description": "后续修改行左边框。", "defaults": { "light": "#eab308cc", "dark": "#facc15ff", "highContrast": "#facc15ff" } },
      { "id": "pentimento.ambiguousBackground", "description": "归属不确定行的背景。", "defaults": { "light": "#9ca3af33", "dark": "#9ca3af40", "highContrast": "#9ca3af66" } },
      { "id": "pentimento.ambiguousBorder", "description": "不确定行左边框。", "defaults": { "light": "#6b7280cc", "dark": "#9ca3afff", "highContrast": "#9ca3afff" } }
    ],
    "configuration": {
      "title": "Pentimento",
      "properties": {
        "pentimento.hover.enabled": { "type": "boolean", "default": false, "markdownDescription": "启用行级 Git Hover(默认关闭,改用右键高亮)。" },
        "pentimento.hover.delay": { "type": "number", "default": 300, "markdownDescription": "Hover 防抖延迟(毫秒)。", "minimum": 0 },
        "pentimento.hover.mode": { "type": "string", "enum": ["compact", "full", "disabled"], "default": "compact", "enumDescriptions": ["紧凑", "完整", "禁用"], "markdownDescription": "Hover 详细程度。" },
        "pentimento.compatibility.mode": { "type": "boolean", "default": true, "markdownDescription": "兼容模式:不显示行尾文字、CodeLens、InlayHint、Gutter 图标。" },
        "pentimento.highlight.style": { "type": "string", "enum": ["background-and-border", "background-only", "border-only", "overview-ruler-only"], "default": "background-and-border", "enumDescriptions": ["背景与左边框", "仅背景", "仅边框", "仅缩略图"], "markdownDescription": "高亮视觉样式。" },
        "pentimento.highlight.wholeLine": { "type": "boolean", "default": true, "markdownDescription": "整行高亮。" },
        "pentimento.highlight.gutterIcon": { "type": "boolean", "default": false, "markdownDescription": "显示 Gutter 图标(默认关闭以免冲突)。" },
        "pentimento.highlight.inlineLabel": { "type": "boolean", "default": false, "markdownDescription": "显示行尾内联标签(默认关闭)。" },
        "pentimento.highlight.overviewRuler": { "type": "boolean", "default": true, "markdownDescription": "在缩略图显示标记。" },
        "pentimento.highlight.currentFileOnlyByDefault": { "type": "boolean", "default": false, "markdownDescription": "默认仅高亮当前文件。" },
        "pentimento.blame.ignoreWhitespace": { "type": "boolean", "default": false, "markdownDescription": "blame 时忽略空白(-w)。" },
        "pentimento.blame.detectMovedLines": { "type": "boolean", "default": true, "markdownDescription": "检测移动行(-M)。" },
        "pentimento.blame.detectCopiedLines": { "type": "boolean", "default": true, "markdownDescription": "检测复制行(-C)。" },
        "pentimento.multiPatch.enabled": { "type": "boolean", "default": true, "markdownDescription": "允许多 Patch 图层。" },
        "pentimento.multiPatch.maxActivePatches": { "type": "number", "default": 6, "minimum": 1, "maximum": 12, "markdownDescription": "同时启用的最大 Patch 数。" },
        "pentimento.multiPatch.hoverDefaultAction": { "type": "string", "enum": ["add", "replace", "ask"], "default": "add", "enumDescriptions": ["添加到现有图层", "替换全部图层", "每次询问"], "markdownDescription": "Hover 添加 Patch 的默认动作。" },
        "pentimento.multiPatch.overlapStyle": { "type": "string", "enum": ["combined"], "default": "combined", "markdownDescription": "重叠行视觉样式。" },
        "pentimento.multiPatch.sortBy": { "type": "string", "enum": ["added", "name", "color"], "default": "added", "enumDescriptions": ["按添加顺序", "按名称", "按颜色"], "markdownDescription": "Patch 在树视图中的排序方式。" },
        "pentimento.multiPatch.groupBy": { "type": "string", "enum": ["none", "viewMode"], "default": "none", "enumDescriptions": ["不分组", "按查看模式分组"], "markdownDescription": "Patch 在树视图中的分组方式。" },
        "pentimento.historical.defaultMode": { "type": "string", "enum": ["ask", "surviving-lines", "exact-patch-revision"], "default": "ask", "enumDescriptions": ["每次询问", "存活行", "精确 Patch 版本"], "markdownDescription": "历史 Patch 默认模式。" },
        "pentimento.historical.preferExactWorktreeForNonAncestor": { "type": "boolean", "default": true, "markdownDescription": "非祖先提交优先使用精确 worktree。" },
        "pentimento.exactPatch.reuseWorktree": { "type": "boolean", "default": true, "markdownDescription": "复用已存在的精确 worktree。" },
        "pentimento.exactPatch.cleanupOnExit": { "type": "boolean", "default": false, "markdownDescription": "插件停用时移除所有受管 worktree。" },
        "pentimento.largePatch.maxFiles": { "type": "number", "default": 500, "minimum": 1, "markdownDescription": "单个 Patch 最多分析的文件数(超出截断)。" },
        "pentimento.largePatch.maxAddedLines": { "type": "number", "default": 20000, "minimum": 1, "markdownDescription": "单个 Patch 最多分析的新增行数(超出截断)。" },
        "pentimento.git.autoFetch.enabled": { "type": "boolean", "default": false, "markdownDescription": "启用后台自动 fetch(仅 fetch,不切换分支/不改工作区)。" },
        "pentimento.git.autoFetch.intervalMinutes": { "type": "number", "default": 30, "minimum": 1, "markdownDescription": "后台自动 fetch 间隔(分钟)。" },
        "pentimento.git.timeout": { "type": "number", "default": 30000, "minimum": 1000, "markdownDescription": "Git 命令超时(毫秒)。" },
        "pentimento.git.maxConcurrentCommands": { "type": "number", "default": 4, "minimum": 1, "maximum": 32, "markdownDescription": "最大并发 Git 命令数。" },
        "pentimento.git.maxOutputBytes": { "type": "number", "default": 52428800, "minimum": 1024, "markdownDescription": "Git 命令最大输出字节数。" },
        "pentimento.logging.level": { "type": "string", "enum": ["error", "warn", "info", "debug", "trace"], "default": "info", "markdownDescription": "输出通道日志级别。" }
      }
    },
    "walkthroughs": [
      {
        "id": "pentimento.gettingStarted",
        "title": "Pentimento 入门",
        "description": "在真实代码中高亮 Git Patch 新增内容",
        "steps": [
          {
            "id": "hover",
            "title": "悬停查看提交",
            "description": "悬停任意代码行,查看其 Git 提交、作者与时间。",
            "media": { "markdown": "悬停代码行即可看到 **Pentimento** Hover,显示提交哈希、作者、时间与摘要,并提供高亮操作。" }
          },
          {
            "id": "highlight",
            "title": "高亮 Patch",
            "description": "点击 Hover 中的「添加此提交到高亮」,将该提交新增行高亮在真实代码中。",
            "media": { "markdown": "高亮以淡色背景 + 左边框呈现,不打开 Diff Editor,不影响代码跳转与语言服务。" },
            "completionEvents": [ "onCommand:pentimento.addCommitFromLine" ]
          },
          {
            "id": "workingTree",
            "title": "高亮未提交修改",
            "description": "直接高亮工作区或暂存区的未提交新增行。",
            "media": { "markdown": "命令面板执行「高亮工作区修改」或「高亮暂存区修改」,无需提交即可看到本地新增内容。" },
            "completionEvents": [ "onCommand:pentimento.highlightWorkingTree" ]
          },
          {
            "id": "historical",
            "title": "历史 Patch 查看",
            "description": "为历史提交选择查看模式:存活行、投影到当前版本、或精确 Patch 版本。",
            "media": { "markdown": "祖先提交默认「存活行」(基于当前 HEAD blame);非祖先提交可「投影」或打开「精确 Patch 工作区」。" },
            "completionEvents": [ "onCommand:pentimento.switchHistoricalViewMode" ]
          },
          {
            "id": "manage",
            "title": "管理多 Patch",
            "description": "在左侧 PENTIMENTO 视图管理多 Patch、Hunk 跳转、精确 worktree。",
            "media": { "markdown": "Activity Bar 的 PENTIMENTO 视图:★ 主要 / ● 启用 / ○ 隐藏,支持添加、显隐、移除、Hunk 导航、精确 Patch 工作区。" },
            "completionEvents": [ "onCommand:pentimento.addRef" ]
          },
          {
            "id": "customize",
            "title": "自定义颜色与排序",
            "description": "为每个 Patch 设置自定义颜色,调整树视图排序与分组。",
            "media": { "markdown": "命令「设置 Patch 颜色」可选预设浅亮色或自定义 hex;在设置中调整 `multiPatch.sortBy` 与 `multiPatch.groupBy`。" },
            "completionEvents": [ "onCommand:pentimento.setPatchColor" ]
          },
          {
            "id": "fetch",
            "title": "受控 Fetch",
            "description": "在 VSCode 内 fetch origin 并刷新高亮,无需打开终端。",
            "media": { "markdown": "命令「Fetch 并刷新」安全拉取 remote-tracking ref(不切换分支、不改工作区);可在设置开启后台自动 fetch。" },
            "completionEvents": [ "onCommand:pentimento.fetch" ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "check": "tsc -p tsconfig.json --noEmit",
    "compile-tests": "tsc -p tsconfig.test.json",
    "lint": "eslint src test",
    "test:unit": "npm run compile-tests && mocha",
    "pretest": "npm run compile && npm run compile-tests",
    "test": "node ./out-test/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/chai": "^4.3.16",
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.0",
    "chai": "^4.4.1",
    "esbuild": "^0.23.0",
    "eslint": "^9.8.0",
